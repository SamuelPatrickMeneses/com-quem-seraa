{
  "name": "com-quem-seraa-monorepo",
  "version": "1.0.0",
  "description": "Monorepo do projeto da disciplina",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run start -w apps/web",
    "dev:web:test": "npm run test -w apps/web",
    "dev:web:build": "npm run build -w apps/web",
    "dev:web:watch": "npm run watch -w apps/web",
    "docker:up": "docker compose --profile dev up --remove-orphans",
    "docker:down": "docker compose --profile '*' down",
    "docker:test": "sh scripts/docker-test.sh",
    "docker:test:filtered": "echo 'Use fdescribe()/fit() in your spec file to filter tests, then run npm run docker:test'",
    "setup:env": "cp -n example.env .env || true"
  },
  "keywords": [
    "angular",
    "supabase",
    "monorepo"
  ],
  "author": "Sua Equipe",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {}
}
